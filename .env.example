# Copy to .env (gitignored). Every variable is optional in development;
# production (TITAN_ENV=production) refuses to boot with dev defaults.

TITAN_ENV=development
TITAN_DATABASE_URL=sqlite:///./titan_metrics.db
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
TITAN_JWT_SECRET=
# Comma-separated exact origins — never "*"
TITAN_CORS_ORIGINS=http://localhost:8081
TITAN_TOKEN_TTL_SECONDS=604800
